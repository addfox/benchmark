# Link workspace packages from addfox monorepo
# This allows using "workspace:*" protocol to link to addfox packages

# Enable workspace protocol for linked packages
link-workspace-packages=true

# Tell pnpm where to find the workspace packages
# Using relative path to addfox monorepo
shared-workspace-lockfile=false

# Addfox packages registry
@addfox:registry=https://registry.npmjs.org/
