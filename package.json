{
  "name": "extension-build-benchmark",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Benchmark dev (command start → ready/browser) and build (time + output size) for addfox, wxt, plasmo, extensionjs",
  "scripts": {
    "benchmark": "node scripts/benchmark.mjs",
    "benchmark:dev": "node scripts/benchmark.mjs --dev-only",
    "benchmark:build": "node scripts/benchmark.mjs --build-only",
    "copy-icons": "node scripts/copy-icons.mjs",
    "test:wxt": "node scripts/dev-benchmark.mjs wxt",
    "test:addfox": "node scripts/dev-benchmark.mjs addfox",
    "test:plasmo": "node scripts/dev-benchmark.mjs plasmo",
    "test:extensionjs": "node scripts/dev-benchmark.mjs extensionjs",
    "build:wxt": "node scripts/build-benchmark.mjs wxt",
    "build:addfox": "node scripts/build-benchmark.mjs addfox",
    "build:plasmo": "node scripts/build-benchmark.mjs plasmo",
    "build:extensionjs": "node scripts/build-benchmark.mjs extensionjs"
  },
  "devDependencies": {
    "picocolors": "^1.1.1"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "addfox": "link:..\\addfox\\packages\\addfox",
      "@addfox/utils": "link:..\\addfox\\packages\\utils",
      "@addfox/core": "link:..\\addfox\\packages\\core",
      "@addfox/common": "link:..\\addfox\\packages\\common",
      "@addfox/cli": "link:..\\addfox\\packages\\cli",
      "@addfox/rsbuild-plugin-extension-entry": "link:..\\addfox\\packages\\plugins\\rsbuild-plugin-extension-entry",
      "@addfox/rsbuild-plugin-extension-hmr": "link:..\\addfox\\packages\\plugins\\rsbuild-plugin-extension-hmr",
      "@addfox/rsbuild-plugin-extension-manifest": "link:..\\..\\addfox\\packages\\plugins\\rsbuild-plugin-extension-manifest",
      "@addfox/rsbuild-plugin-extension-monitor": "link:..\\..\\addfox\\packages\\plugins\\rsbuild-plugin-extension-monitor",
      "@addfox/rsbuild-plugin-vue": "link:..\\..\\addfox\\packages\\plugins\\rsbuild-plugin-vue",
      "@addfox/launcher": "link:..\\addfox\\packages\\launcher",
      "@addfox/pkg-manager": "link:..\\addfox\\packages\\pkg-manager"
    }
  },
  "dependencies": {
    "@addfox/cli": "link:..\\addfox\\packages\\cli",
    "@addfox/common": "link:..\\addfox\\packages\\common",
    "@addfox/core": "link:..\\addfox\\packages\\core",
    "@addfox/launcher": "link:..\\addfox\\packages\\launcher",
    "@addfox/pkg-manager": "link:..\\addfox\\packages\\pkg-manager",
    "@addfox/rsbuild-plugin-extension-entry": "link:..\\addfox\\packages\\plugins\\rsbuild-plugin-extension-entry",
    "@addfox/rsbuild-plugin-extension-hmr": "link:..\\addfox\\packages\\plugins\\rsbuild-plugin-extension-hmr",
    "@addfox/rsbuild-plugin-extension-manifest": "link:..\\addfox\\packages\\plugins\\rsbuild-plugin-extension-manifest",
    "@addfox/rsbuild-plugin-extension-monitor": "link:..\\addfox\\packages\\plugins\\rsbuild-plugin-extension-monitor",
    "@addfox/rsbuild-plugin-vue": "link:..\\addfox\\packages\\plugins\\rsbuild-plugin-vue",
    "@addfox/utils": "link:..\\addfox\\packages\\utils",
    "addfox": "link:..\\addfox\\packages\\addfox"
  }
}
