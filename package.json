{
  "name": "extension-build-benchmark",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Benchmark dev (command start → ready/browser) and build (time + output size) for addfox, wxt, plasmo, extensionjs",
  "scripts": {
    "benchmark": "node scripts/benchmark.mjs",
    "benchmark:dev": "node scripts/benchmark.mjs --dev-only",
    "benchmark:build": "node scripts/benchmark.mjs --build-only",
    "copy-icons": "node scripts/copy-icons.mjs",
    "test:wxt": "node scripts/dev-benchmark.mjs wxt",
    "test:addfox": "node scripts/dev-benchmark.mjs addfox",
    "test:plasmo": "node scripts/dev-benchmark.mjs plasmo",
    "test:extensionjs": "node scripts/dev-benchmark.mjs extensionjs",
    "build:wxt": "node scripts/build-benchmark.mjs wxt",
    "build:addfox": "node scripts/build-benchmark.mjs addfox",
    "build:plasmo": "node scripts/build-benchmark.mjs plasmo",
    "build:extensionjs": "node scripts/build-benchmark.mjs extensionjs"
  },
  "devDependencies": {
    "picocolors": "^1.1.1"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "overrides": {
      "addfox": "file:addfox/.yalc/addfox",
      "@addfox/utils": "file:addfox/.yalc/@addfox/utils"
    }
  }
}
